# POLYPROPHET Environment Variables
# Copy this file to .env and fill in your values
# NEVER COMMIT YOUR ACTUAL .env FILE TO GITHUB!

# ==================== POLYMARKET API ====================
# Get these from: https://polymarket.com/api
POLYMARKET_API_KEY=your-api-key-here
POLYMARKET_SECRET=your-secret-here
POLYMARKET_PASSPHRASE=your-passphrase-here

# Your wallet address on Polygon (same as MetaMask)
POLYMARKET_ADDRESS=0xYourWalletAddress

# Private key for signing transactions (NEVER SHARE!)
POLYMARKET_PRIVATE_KEY=0xYourPrivateKeyForLiveTrading

# Optional: Proxy key if using Polymarket proxy
POLYMARKET_PROXY_KEY=your-proxy-key-optional

# ==================== TRADING CONFIG ====================
# PAPER = simulated trading, LIVE = real money
TRADE_MODE=PAPER

# Starting balance for paper trading
PAPER_BALANCE=1000

# Fallback balance for live trading (actual balance is fetched from chain)
LIVE_BALANCE=1000

# Maximum position size as percentage of balance (0.10 = 10%)
MAX_POSITION_SIZE=0.10

# ==================== AUTHENTICATION ====================
# Dashboard login credentials (used for http://localhost:3000)
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme

# ==================== REDIS (for Render/Cloud) ====================
# Optional: Redis URL for persistent storage
# Without this, data resets on restart
# REDIS_URL=redis://...your-redis-url...
