# Trading mode
TRADE_MODE=PAPER
ENABLE_LIVE_TRADING=0
LIVE_AUTOTRADING_ENABLED=false
ASSETS=BTC,ETH,SOL,XRP
TIMEFRAME_15M_ENABLED=true
TIMEFRAME_5M_ENABLED=false
MULTIFRAME_4H_ENABLED=false
TIMEFRAME_15M_MIN_BANKROLL=2
TIMEFRAME_4H_MIN_BANKROLL=10
TIMEFRAME_5M_MIN_BANKROLL=50

# Strategy set (uncapped-growth beam_2739 is default primary in server.js)
# Override with env var if needed:
# STRATEGY_SET_15M_PATH=debug/strategy_set_definitive_uncapped_growth_best.json
STRATEGY_SET_4H_PATH=debug/strategy_set_4h_maxprofit.json
STRATEGY_SET_5M_PATH=debug/strategy_set_5m_maxprofit.json

# Uncapped-growth guard configuration (matches simulation)
RISK_ENVELOPE_ENABLED=false
MAX_TOTAL_EXPOSURE=0
MAX_ABSOLUTE_STAKE_SMALL=100000
MAX_ABSOLUTE_STAKE_MEDIUM=100000
MAX_ABSOLUTE_STAKE_LARGE=100000

# Polymarket wallet (required for LIVE trading)
POLYMARKET_PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PASSPHRASE=
POLYMARKET_SIGNATURE_TYPE=1
POLYMARKET_ADDRESS=
POLYMARKET_AUTO_DERIVE_CREDS=true
POLYMARKET_RELAYER_URL=https://relayer-v2.polymarket.com
# Optional relayer auth for automatic proxy redemptions (use either relayer API key or builder creds)
POLYMARKET_RELAYER_API_KEY=
POLYMARKET_RELAYER_API_KEY_ADDRESS=
POLYMARKET_BUILDER_API_KEY=
POLYMARKET_BUILDER_SECRET=
POLYMARKET_BUILDER_PASSPHRASE=

# Optional proxy routing for Render / Cloudflare-sensitive requests
PROXY_URL=
CLOB_FORCE_PROXY=0

# Starting balance
STARTING_BALANCE=20
OPERATOR_STAKE_FRACTION=0.45

# Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_SIGNALS_ONLY=false

# Server
PORT=3000
